# ============================================================
# ARIA — Environment template (Dokploy / production)
# Copy to .env and fill real values. Never commit .env.
# ============================================================

# --- Public hostnames (used by Traefik routers + CORS + MCP URL) ---
FRONTEND_HOST=aria.vgtray.fr
BACKEND_HOST=aria-backend.vgtray.fr

# --- TimescaleDB ---
# Pick a strong password (no host port is exposed — DB is internal only).
POSTGRES_USER=aria
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=aria

# --- Backend (FastAPI) ---
# JWT_SECRET_KEY  : openssl rand -hex 32
# MCP_API_KEY     : openssl rand -hex 32
JWT_SECRET_KEY=change-me-openssl-rand-hex-32
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7
MCP_API_KEY=change-me-openssl-rand-hex-32

# --- Anthropic / Agents ---
ANTHROPIC_API_KEY=sk-ant-replace-me
# Model tier used by agents. sonnet (default, cheap) | opus (demo).
ARIA_MODEL=sonnet

# --- Managed Agents (Investigator) ---
# When true the Investigator runs on Anthropic's hosted agent loop with
# hosted MCP and a sandboxed Python container. ARIA_MCP_PUBLIC_URL is
# auto-built from BACKEND_HOST + ARIA_MCP_PATH_SECRET in docker-compose.
# Generate the secret with: openssl rand -hex 32
INVESTIGATOR_USE_MANAGED=true
ARIA_MCP_PATH_SECRET=change-me-openssl-rand-hex-32

# --- Demo ---
# Exposes the demo control endpoints (scenario triggers). Off in real prod.
ARIA_DEMO_ENABLED=true

# --- Simulators ---
# realtime : 1 simulated sec = 1 real sec, cells idle near nominal.
# demo     : compress 72h scenario into ~4 minutes (Filler breaches alone).
SIMULATOR_MODE=realtime
SIMULATOR_TICK_INTERVAL_S=1.0
